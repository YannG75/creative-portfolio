---
/* Glyphes Unicode directement, pas d'iconify */
---

<section id="skills" class="skills-section" aria-labelledby="skills-title">
  <!-- Décorations -->
  <div class="skills-bg" aria-hidden="true">
    <div class="halo halo-purple" style="top:5%;  left:-5%;  width:550px; height:450px;"></div>
    <div class="halo halo-cyan"   style="top:40%; right:-4%; width:500px; height:400px; opacity:0.35;"></div>
  </div>

  <!-- En-tête section -->
  <div class="skills-header scan-in" data-delay="0">
    <span class="section-label">// 02 · COMPÉTENCES</span>
    <div class="header-line" aria-hidden="true"></div>
  </div>

  <!-- Titre -->
  <div class="skills-title-block scan-in" data-delay="1">
    <div class="title-row">
      <h2 id="skills-title" class="skills-title">STATUS PANEL</h2>
      <div class="level-badge" aria-label="Niveau maximum">LVL.MAX</div>
    </div>
    <p class="skills-subtitle">Stack technique · juin 2026</p>
  </div>

  <!-- Layout 2 colonnes -->
  <div class="skills-body scan-in" data-delay="2">

    <!-- ─ Panneau gauche ─ -->
    <div class="left-panel">

      <!-- En-tête du panel -->
      <div class="lp-header">
        <span class="lp-title">CORE TECHNOLOGIES</span>
        <span class="lp-version">v2.0.26</span>
      </div>

      <!-- Zone vedette : 1 ligne de 4 chips (ROW) -->
      <div class="featured-zone">
        <div class="featured-hdr">
          <span class="feat-star" aria-hidden="true">★</span>
          <span class="feat-label">COMPÉTENCES PHARES</span>
        </div>
        <div class="featured-row" role="list">
          {[
            { g: '△',  n: 'Three.js',          d: '3D Rendering' },
            { g: 'R3', n: 'React Three Fiber',  d: '3D React' },
            { g: 'GS', n: 'GSAP',              d: 'Animations' },
            { g: '⚛',  n: 'React',             d: 'UI Framework' },
          ].map(f => (
            <div class="feat-chip" role="listitem">
              <div class="feat-icon-box" aria-hidden="true">{f.g}</div>
              <div class="feat-text">
                <span class="feat-name">{f.n}</span>
                <span class="feat-desc">{f.d}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Cat CORE -->
      <div class="cat-section" aria-label="Technologies core">
        <div class="cat-hdr">
          <div class="cat-hdr-row">
            <div class="accent-bar accent-cyan" aria-hidden="true"></div>
            <span class="cat-label cat-cyan">CORE</span>
          </div>
          <p class="cat-desc">Frameworks &amp; langages fondamentaux pour des apps modernes et performantes</p>
        </div>
        <div class="tags-row" role="list">
          {[
            { g: '⚛',  n: 'React'      },
            { g: 'N→', n: 'Next.js'    },
            { g: 'V',  n: 'Vue 3'      },
            { g: 'N',  n: 'Nuxt'       },
            { g: 'TS', n: 'TypeScript'  },
            { g: 'JS', n: 'JavaScript'  },
          ].map(t => (
            <span class="tag tag-cyan" role="listitem">
              <b class="tag-icon">{t.g}</b>{t.n}
            </span>
          ))}
        </div>
      </div>

      <!-- Cat CRÉATIF -->
      <div class="cat-section" aria-label="Technologies créatives">
        <div class="cat-hdr">
          <div class="cat-hdr-row">
            <div class="accent-bar accent-purple" aria-hidden="true"></div>
            <span class="cat-label cat-purple">CRÉATIF</span>
          </div>
          <p class="cat-desc">WebGL, 3D temps réel et motion design pour des interfaces hors du commun</p>
        </div>
        <div class="tags-row" role="list">
          {[
            { g: '△',  n: 'Three.js'         },
            { g: 'R3', n: 'React Three Fiber' },
            { g: 'GS', n: 'GSAP'             },
            { g: 'FM', n: 'Framer Motion'    },
            { g: 'GL', n: 'WebGL / GLSL'     },
            { g: 'CV', n: 'Canvas API'        },
          ].map(t => (
            <span class="tag tag-purple" role="listitem">
              <b class="tag-icon">{t.g}</b>{t.n}
            </span>
          ))}
        </div>
      </div>

      <!-- Cat OUTILS -->
      <div class="cat-section" aria-label="Outils et workflow">
        <div class="cat-hdr">
          <div class="cat-hdr-row">
            <div class="accent-bar accent-code" aria-hidden="true"></div>
            <span class="cat-label cat-code">OUTILS</span>
          </div>
          <p class="cat-desc">Outillage, infra et services pour shipper vite et bien</p>
        </div>
        <div class="tags-row" role="list">
          {[
            { g: '◎',  n: 'Figma'          },
            { g: '⚡',  n: 'Vite'           },
            { g: 'TW', n: 'Tailwind CSS'   },
            { g: 'N', n: 'Neon'       },
            { g: 'GH', n: 'GitHub Actions' },
            { g: 'NJ', n: 'Node.js'        },
          ].map(t => (
            <span class="tag tag-code" role="listitem">
              <b class="tag-icon">{t.g}</b>{t.n}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- ─ Colonne droite ─ -->
    <div class="right-column">

      <!-- Tools panel -->
      <div class="right-panel right-panel-purple">
        <div class="rp-header">
          <span class="rp-title">TOOLS &amp; ECOSYSTEM</span>
        </div>
        <ul class="tools-list" role="list">
          {[
            { g: '◈', n: 'VS Code - phpstorm - webstorm'},
            { g: '⌥', n: 'Git & GitHub'  },
            { g: '◎', n: 'Figma'         },
            { g: '▷', n: 'Postman'       },
            { g: '⊛', n: 'Vercel'        },
            { g: '⊛', n: 'Pencil'        },
          ].map(t => (
            <li class="tool-row" role="listitem">
              <span class="tool-icon" aria-hidden="true">{t.g}</span>
              <span class="tool-name">{t.n}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- XP panel -->
      <div class="right-panel right-panel-cyan">
        <div class="rp-header">
          <span class="rp-title">EXPÉRIENCE</span>
        </div>
        <ul class="xp-list" role="list">
          {[
            { company: 'Freelance', period: 'now', role: 'Creative Developer' },
            { company: 'Madmix Digital', period: '2021–2024', role: 'Front-End Developer'  },
            { company: 'Smartness',    period: '2020–2021', role: 'Front-End Developer' },
          ].map(xp => (
            <li class="xp-entry" role="listitem">
              <div class="xp-top">
                <span class="xp-company">{xp.company}</span>
                <span class="xp-period">{xp.period}</span>
              </div>
              <span class="xp-role">{xp.role}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .skills-section {
    position: relative;
    padding: 80px clamp(24px, 8.3vw, 120px);
    background-color: var(--bg-deep);
    overflow: hidden;
  }

  .skills-bg {
    position: absolute; inset: 0;
    pointer-events: none; z-index: 0;
  }
  .halo {
    position: absolute; border-radius: 50%;
    filter: blur(90px);
  }
  .halo-cyan   { background: radial-gradient(circle, rgba(0,229,255,0.22) 0%, transparent 70%); }
  .halo-purple { background: radial-gradient(circle, rgba(168,85,247,0.28) 0%, transparent 70%); }

  /* ─── En-tête ─── */
  .skills-header {
    position: relative; z-index: 1;
    display: flex; align-items: center; gap: 20px;
    margin-bottom: 20px;
  }
  .header-line {
    flex: 1; height: 1px;
    background: linear-gradient(90deg, var(--border-cyan), transparent);
  }

  .skills-title-block {
    position: relative; z-index: 1;
    margin-bottom: 40px;
  }

  .title-row {
    display: flex; align-items: center; gap: 20px;
    margin-bottom: 6px;
  }

  .skills-title {
    font-family: var(--font-geist);
    font-size: clamp(36px, 3.6vw, 52px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    line-height: 1;
  }

  .level-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--accent-purple);
    background: rgba(168, 85, 247, 0.19);
    border: 1px solid rgba(168, 85, 247, 0.19);
    border-radius: 4px;
    padding: 6px 14px;
  }

  .skills-subtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  /* ─── Body 2 colonnes ─── */
  .skills-body {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 32px;
    align-items: start;
  }

  /* ─── Left Panel ─── */
  .left-panel {
    background: linear-gradient(160deg, #0D1A2E, #091420);
    border: 1px solid rgba(0, 229, 255, 0.31);
    border-radius: 8px;
    box-shadow: 0 0 30px rgba(0, 229, 255, 0.08);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .lp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    background: rgba(0, 229, 255, 0.19);
    border-bottom: 1px solid #1B3050;
    border-radius: 8px 8px 0 0;
  }
  .lp-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--accent-cyan);
  }
  .lp-version {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: #6B8BAF;
  }

  /* ─── Featured Zone : ROW horizontal ─── */
  .featured-zone {
    padding: 18px 24px;
    border-bottom: 1px solid #1B3050;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .featured-hdr {
    display: flex; align-items: center; gap: 8px;
  }
  .feat-star {
    color: var(--accent-cyan);
    font-size: 10px;
  }
  .feat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--accent-cyan);
  }

  /* ROW de 4 chips côte à côte */
  .featured-row {
    display: flex;
    flex-direction: row;
    gap: 10px;
    flex-wrap: wrap;
  }

  .feat-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    background: linear-gradient(135deg, rgba(0,229,255,0.094), rgba(168,85,247,0.063));
    border: 1px solid rgba(0, 229, 255, 0.31);
    border-radius: 6px;
    box-shadow: 0 0 14px rgba(0, 229, 255, 0.145);
    flex: 1;
    min-width: 0;
  }

  .feat-icon-box {
    width: 28px; height: 28px;
    border-radius: 4px;
    background: rgba(0, 229, 255, 0.082);
    border: 1px solid rgba(0, 229, 255, 0.31);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    color: var(--accent-cyan);
    flex-shrink: 0;
  }

  .feat-text {
    display: flex; flex-direction: column; gap: 2px;
    min-width: 0;
  }
  .feat-name {
    font-family: var(--font-geist);
    font-size: 12px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .feat-desc {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  /* ─── Catégories ─── */
  .cat-section {
    padding: 18px 24px;
    border-bottom: 1px solid #1B3050;
  }
  .cat-section:last-child { border-bottom: none; }

  .cat-hdr { display: flex; flex-direction: column; gap: 4px; margin-bottom: 14px; }
  .cat-hdr-row { display: flex; align-items: center; gap: 8px; }

  .accent-bar {
    width: 3px; height: 14px;
    border-radius: 2px; flex-shrink: 0;
  }
  .accent-cyan   { background: var(--accent-cyan); }
  .accent-purple { background: var(--accent-purple); }
  .accent-code   { background: #7EDDFA; }

  .cat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    font-weight: 600;
  }
  .cat-cyan   { color: var(--accent-cyan); }
  .cat-purple { color: var(--accent-purple); }
  .cat-code   { color: #7EDDFA; }

  .cat-desc {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #6B8BAF;
    line-height: 1.5;
  }

  /* Tags */
  .tags-row {
    display: flex; flex-wrap: wrap; gap: 7px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    cursor: default;
    transition: filter 0.2s;
  }
  .tag:hover { filter: brightness(1.15); }

  .tag-icon {
    font-size: 9px;
    font-weight: 700;
  }

  /* CORE : fill #00E5FF30 ≈ 19%, border #00E5FF50 ≈ 31% */
  .tag-cyan {
    background: rgba(0, 229, 255, 0.188);
    border: 1px solid rgba(0, 229, 255, 0.314);
    color: var(--accent-cyan);
  }
  /* CRÉATIF : fill #A855F730, border #A855F730 */
  .tag-purple {
    background: rgba(168, 85, 247, 0.188);
    border: 1px solid rgba(168, 85, 247, 0.188);
    color: var(--accent-purple);
  }
  /* OUTILS : fill #1B3050, border #1B3050, texte #7EDDFA */
  .tag-code {
    background: #1B3050;
    border: 1px solid #1B3050;
    color: #7EDDFA;
  }

  /* ─── Colonne droite ─── */
  .right-column {
    display: flex; flex-direction: column; gap: 24px;
  }

  .right-panel {
    border-radius: 8px;
    overflow: hidden;
  }

  .right-panel-purple {
    background: linear-gradient(145deg, #100D20, #091420);
    border: 1px solid rgba(168, 85, 247, 0.188);
    box-shadow: 0 0 25px rgba(168, 85, 247, 0.082);
  }
  .right-panel-cyan {
    background: #0D1A2E;
    border: 1px solid #1B3050;
  }

  .rp-header {
    padding: 11px 18px;
    border-bottom: 1px solid rgba(168, 85, 247, 0.2);
    background: rgba(168, 85, 247, 0.05);
  }
  .right-panel-cyan .rp-header {
    border-bottom-color: rgba(0, 229, 255, 0.14);
    background: rgba(0, 229, 255, 0.04);
  }
  .rp-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: rgba(168, 85, 247, 0.75);
  }
  .right-panel-cyan .rp-title { color: rgba(0, 229, 255, 0.65); }

  .tools-list { list-style: none; }
  .tool-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s;
  }
  .tool-row:last-child { border-bottom: none; }
  .tool-row:hover { background: rgba(255,255,255,0.025); }

  .tool-icon {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--accent-purple);
    width: 18px; text-align: center; flex-shrink: 0;
  }
  .tool-name {
    font-family: var(--font-geist); font-size: 13px;
    color: var(--text-secondary);
  }

  .xp-list { list-style: none; }
  .xp-entry {
    display: flex; flex-direction: column; gap: 3px;
    padding: 12px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s;
  }
  .xp-entry:last-child { border-bottom: none; }
  .xp-entry:hover { background: rgba(255,255,255,0.02); }

  .xp-top {
    display: flex; align-items: baseline;
    justify-content: space-between; gap: 8px;
  }
  .xp-company {
    font-family: var(--font-geist); font-size: 14px;
    font-weight: 600; color: var(--text-primary);
  }
  .xp-period {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.08em; color: var(--accent-cyan);
  }
  .xp-role {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.04em; color: var(--text-muted);
  }

  /* ─── Responsive ─── */
  @media (max-width: 1100px) {
    .skills-body { grid-template-columns: 1fr; }
    .right-column { flex-direction: row; flex-wrap: wrap; }
    .right-panel  { flex: 1; min-width: 280px; }
    .featured-row { flex-wrap: wrap; }
    .feat-chip { flex: 1 1 calc(50% - 5px); }
  }

  @media (max-width: 768px) {
    .skills-section { padding: 80px 24px; }
    .right-column { flex-direction: column; }
    .featured-row { flex-wrap: wrap; }
    .feat-chip { flex: 1 1 100%; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible')
          observer.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.08 },
  )
  document.querySelectorAll('#skills .scan-in').forEach(el => observer.observe(el))
</script>
